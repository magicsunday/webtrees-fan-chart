{
    "name": "webtrees-fan-chart",
    "version": "3.6.7-dev",
    "description": "This modules provides an SVG ancestor fan chart for the [webtrees](https://www.webtrees.net) genealogy application.",
    "keywords": [
        "webtrees",
        "module",
        "fan",
        "chart"
    ],
    "type": "module",
    "homepage": "https://github.com/magicsunday/webtrees-fan-chart",
    "license": "GPL-3.0-or-later",
    "author": "Rico Sonntag <mail@ricosonntag.de>",
    "repository": {
        "type": "git",
        "url": "https://github.com/magicsunday/webtrees-fan-chart.git"
    },
    "scripts": {
        "prepare": "rollup --config rollup.config.js",
        "watch": "rollup --watch --config rollup.config.js",
        "test": "node --no-warnings --experimental-vm-modules node_modules/jest/bin/jest.js --passWithNoTests",
        "test:coverage": "node --no-warnings --experimental-vm-modules node_modules/jest/bin/jest.js --coverage",
        "test:exports": "node --no-warnings --experimental-vm-modules node_modules/jest/bin/jest.js --runTestsByPath resources/js/tests/export.integration.test.js resources/js/tests/export.large.integration.test.js",
        "test:watch": "node --no-warnings --experimental-vm-modules node_modules/jest/bin/jest.js --watch",
        "lint": "biome lint --error-on-warnings resources/js/modules/",
        "lint:fix": "biome lint --fix --unsafe resources/js/modules/",
        "format": "biome format --write resources/js/modules/ resources/js/tests/",
        "format:check": "biome format resources/js/modules/ resources/js/tests/",
        "typecheck": "tsc --noEmit -p jsconfig.json"
    },
    "devDependencies": {
        "@biomejs/biome": "2.4.16",
        "@rollup/plugin-node-resolve": "^16.0",
        "@rollup/plugin-terser": "^1.0",
        "@types/d3-fetch": "^3.0.7",
        "@types/d3-hierarchy": "^3.1.7",
        "@types/d3-path": "^3.1.1",
        "@types/d3-scale": "^4.0.9",
        "@types/d3-selection": "^3.0.11",
        "@types/d3-shape": "^3.1.8",
        "@types/d3-timer": "^3.0.2",
        "@types/d3-transition": "^3.0.9",
        "@types/d3-zoom": "^3.0.8",
        "@types/jest": "^30.0.0",
        "d3-fetch": "^3.0",
        "d3-hierarchy": "^3.0",
        "d3-path": "^3.0",
        "d3-scale": "^4.0",
        "d3-selection": "^3.0",
        "d3-shape": "^3.0",
        "d3-timer": "^3.0",
        "d3-transition": "^3.0",
        "d3-zoom": "^3.0",
        "jest": "^30.4",
        "jest-environment-jsdom": "^30.4",
        "jscpd": "^4.2.4",
        "pixelmatch": "^7.0",
        "playwright": "^1.60",
        "pngjs": "^7.0",
        "rollup": "^4.60",
        "rollup-plugin-license": "^3.0",
        "typescript": "^6.0.3"
    },
    "dependencies": {
        "@magicsunday/webtrees-chart-lib": "github:magicsunday/webtrees-chart-lib#1.14.0"
    }
}
