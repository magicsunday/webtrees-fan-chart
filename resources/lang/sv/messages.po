#: resources/views/modules/fan-chart/form/date-precision.phtml:34
msgid "Show full birth and death dates for early generations. Marriage dates switch to year-only from generation 7 and are hidden from generation 9."
msgstr "Visa fullständiga födelse- och dödsdatum för tidiga generationer. Äktenskapsdatum visar bara år från generation 7 och döljs från generation 9."

#: src/Configuration.php:191
msgid "Years only"
msgstr "Endast år"

#: src/Configuration.php:195
#, php-format
msgid "Show full dates up to generation %s"
msgstr "Visa fullständiga datum till generation %s"

msgid "Show images"
msgstr "Visa bilder"

msgid "Displays thumbnail images in the inner arcs and the center of the chart. Images are only shown if the arc segment is wide enough."
msgstr "Visar miniatyrbilder i de inre bågarna och i mitten av diagrammet. Bilder visas bara om bågsegmentet är tillräckligt brett."

msgid "Show names"
msgstr "Visa namn"

msgid "Displays names and dates in the chart segments. When disabled, outer generations beyond the inner arcs are hidden."
msgstr "Visar namn och datum i diagramsegmenten. När inaktiverat döljs yttre generationer bortom de inre bågarna."
