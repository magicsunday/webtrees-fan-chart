msgstr "Diagram verplaatsen"

msgid "Click on a person"
msgstr "Klik op een persoon"

msgid "Reload chart for that person"
msgstr "Diagram voor die persoon herladen"

#: resources/views/modules/fan-chart/form/date-precision.phtml:22
msgid "Birth and death date precision"
msgstr "Nauwkeurigheid geboorte- en overlijdensdatum"

#: resources/views/modules/fan-chart/form/date-precision.phtml:34
msgid "Show full birth and death dates for early generations. Marriage dates switch to year-only from generation 7 and are hidden from generation 9."
msgstr "Toon volledige geboorte- en overlijdensdata voor vroege generaties. Huwelijksdata tonen alleen het jaar vanaf generatie 7 en worden verborgen vanaf generatie 9."

#: src/Configuration.php:191
msgid "Years only"
msgstr "Alleen jaren"

#: src/Configuration.php:195
#, php-format
msgid "Show full dates up to generation %s"
msgstr "Toon volledige data tot generatie %s"

msgid "Show images"
msgstr "Afbeeldingen tonen"

msgid "Displays thumbnail images in the inner arcs and the center of the chart. Images are only shown if the arc segment is wide enough."
msgstr "Toont miniatuurafbeeldingen in de binnenste bogen en het midden van het diagram. Afbeeldingen worden alleen getoond als het boogsegment breed genoeg is."

msgid "Show names"
msgstr "Namen tonen"

msgid "Displays names and dates in the chart segments."
msgstr "Toont namen en datums in de diagramsegmenten."
