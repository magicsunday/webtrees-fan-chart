msgstr "Độ chính xác ngày sinh và ngày mất"

#: resources/views/modules/fan-chart/form/date-precision.phtml:34
msgid "Show full birth and death dates for early generations. Marriage dates switch to year-only from generation 7 and are hidden from generation 9."
msgstr "Hiển thị đầy đủ ngày sinh và ngày mất cho các thế hệ đầu tiên. Ngày kết hôn chỉ hiển thị năm từ thế hệ 7 và được ẩn từ thế hệ 9."

#: src/Configuration.php:191
msgid "Years only"
msgstr "Chỉ năm"

#: src/Configuration.php:195
#, php-format
msgid "Show full dates up to generation %s"
msgstr "Hiển thị đầy đủ ngày tháng đến thế hệ %s"

msgid "Show images"
msgstr "Hiển thị hình ảnh"

msgid "Displays thumbnail images in the inner arcs and the center of the chart. Images are only shown if the arc segment is wide enough."
msgstr "Hiển thị hình thu nhỏ trong các cung bên trong và ở giữa biểu đồ. Hình ảnh chỉ hiển thị khi đoạn cung đủ rộng."

msgid "Show names"
msgstr "Hiển thị tên"

msgid "Displays names and dates in the chart segments. When disabled, outer generations beyond the inner arcs are hidden."
msgstr "Hiển thị tên và ngày tháng trong các phân đoạn biểu đồ. Khi tắt, các thế hệ bên ngoài vượt quá các cung bên trong sẽ bị ẩn."
