#: src/Module.php:127 src/Module.php:243
msgid "Fan chart"
msgstr "Diagrama em leque"

#: src/Module.php:137
msgid "A fan chart of an individual’s ancestors."
msgstr "Diagrama em leque dos ascendentes de um indivíduo."

#: src/Module.php:240 src/Traits/ModuleChartTrait.php:41
#, php-format
msgid "Fan chart of %s"
msgstr "Diagrama em leque de %s"

#: src/Module.php:260
msgid "Use Ctrl + scroll to zoom in the view"
msgstr "Usar Ctrl + roda do rato para aproximar ou afastar"

#: src/Module.php:261
msgid "Move the view with two fingers"
msgstr "Mover a vista com dois dedos"

#: src/Traits/ModuleConfigTrait.php:99
#, php-format
msgid "The preferences for the module “%s” have been updated."
msgstr "As preferências do módulo \"%s\" foram atualizadas."

#: resources/views/modules/components/buttonbar/center-button.phtml:18
msgid "Re center"
msgstr "Recentrar"

#: resources/views/modules/components/buttonbar/fullscreen-button.phtml:18
