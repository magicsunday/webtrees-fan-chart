#: resources/views/modules/fan-chart/form/date-precision.phtml:22
msgid "Birth and death date precision"
msgstr "Precisión de fechas de nacimiento y defunción"

#: resources/views/modules/fan-chart/form/date-precision.phtml:34
msgid "Show full birth and death dates for early generations. Marriage dates switch to year-only from generation 7 and are hidden from generation 9. Descendants with narrow arcs automatically use a compact year-only format."
msgstr "Mostrar fechas completas de nacimiento y defunción para las primeras generaciones. Las fechas de matrimonio muestran solo el año a partir de la generación 7 y se ocultan a partir de la generación 9. Los descendientes con arcos estrechos usan automáticamente un formato compacto de solo año."

#: src/Configuration.php:191
msgid "Years only"
msgstr "Solo años"

#: src/Configuration.php:195
#, php-format
msgid "Show full dates up to generation %s"
msgstr "Mostrar fechas completas hasta la generación %s"

msgid "Show descendants"
msgstr "Mostrar descendientes"

msgid "Partners and children are shown as arcs below the ancestor section. The fan size is limited to 180–270 degrees when enabled."
msgstr "Los cónyuges e hijos se muestran como arcos debajo de la sección de antepasados. El tamaño del abanico se limita a 180–270 grados cuando está activado."

msgid "Show names and images"
msgstr "Mostrar nombres e imágenes"

msgid "Show names only"
msgstr "Mostrar solo nombres"

msgid "Show images only"
msgstr "Mostrar solo imágenes"

msgid "Images are only shown if the arc segment is wide enough. Images for descendants are not yet available."
msgstr "Las imágenes solo se muestran si el segmento del arco es lo suficientemente ancho. Las imágenes para los descendientes aún no están disponibles."

