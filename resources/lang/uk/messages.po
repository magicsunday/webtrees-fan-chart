msgid "Right-click"
msgstr "Клік правою кнопкою"

msgid "Show details of a person"
msgstr "Показати деталі про особу"

msgid "Ctrl + scroll"
msgstr "Ctrl + прокрутка"

msgid "Zoom in/out"
msgstr "Збільшити/Зменшити"

msgid "Click and drag"
msgstr "Натисніть і перетягніть"

msgid "Move the chart"
msgstr "Перемістити діаграму"

msgid "Click on a person"
msgstr "Натисніть на особу"

msgid "Reload chart for that person"
msgstr "Перезавантажити діаграму для цієї особи"

#: resources/views/modules/fan-chart/form/date-precision.phtml:22
msgid "Birth and death date precision"
msgstr "Точність дат народження та смерті"

#: resources/views/modules/fan-chart/form/date-precision.phtml:34
msgid "Show full birth and death dates for early generations. Marriage dates switch to year-only from generation 7 and are hidden from generation 9. Descendants with narrow arcs automatically use a compact year-only format."
msgstr "Показувати повні дати народження та смерті для ранніх поколінь. Дати шлюбу відображаються лише як рік починаючи з покоління 7 і приховуються починаючи з покоління 9. Нащадки з вузькими дугами автоматично використовують компактний формат лише з роком."

#: src/Configuration.php:191
msgid "Years only"
msgstr "Лише роки"

#: src/Configuration.php:195
#, php-format
msgid "Show full dates up to generation %s"
msgstr "Показати повні дати до покоління %s"

msgid "Show descendants"
msgstr "Показати нащадків"

msgid "Partners and children are shown as arcs below the ancestor section. The fan size is limited to 180–270 degrees when enabled."
msgstr "Подружжя та діти відображаються у вигляді дуг під секцією предків. Розмір віяла обмежений 180–270 градусами при увімкненні."

msgid "Show names and images"
msgstr "Показати імена та зображення"

msgid "Show names only"
msgstr "Показати лише імена"

msgid "Show images only"
msgstr "Показати лише зображення"

msgid "Images are only shown if the arc segment is wide enough. Images for descendants are not yet available."
msgstr "Зображення показуються лише якщо сегмент дуги достатньо широкий. Зображення для нащадків поки що недоступні."

msgid "Display"
msgstr "Відображення"

