declare(strict_types=1);

/**
 * A range slider with a live-updating output display.
 *
 * @var string      $id      The input element ID and name
 * @var string      $label   The translated label text
 * @var int|float   $value   The current value
 * @var int|float   $min     Minimum allowed value
 * @var int|float   $max     Maximum allowed value
 * @var int|float   $step    Step increment (default: 1)
 * @var string|null $suffix  Optional suffix for the output display (e.g. "°", "%")
 * @var string|null $description Optional help text below the slider
 */

$step   ??= 1;
$suffix ??= '';

?>

<div class="row">
    <label class="col-sm-3 col-form-label wt-page-options-label" for="<?= e($id) ?>">
        <?= $label ?>
    </label>
    <div class="col-sm-9 wt-page-options-value">
        <div class="d-flex justify-content-between">
            <input id="<?= e($id) ?>"
                   name="<?= e($id) ?>"
                   class="flex-grow-1 custom-range"
                   type="range"
                   value="<?= e((string) $value) ?>"
                   min="<?= e((string) $min) ?>"
                   max="<?= e((string) $max) ?>"
                   step="<?= e((string) $step) ?>">
            <output id="<?= e($id) ?>Output"
                    name="<?= e($id) ?>Output"
                    class="custom-range-value wt-page-options-label ms-3"><?= e((string) $value) ?><?= e($suffix) ?></output>
        </div>
        <?php if (isset($description) && ($description !== '')) : ?>
            <small class="form-text text-muted">
                <?= $description ?>
            </small>
        <?php endif ?>
    </div>
</div>
