declare(strict_types=1);

/**
 * A range slider with a live-updating output display.
 *
 * @var string      $id      The input element ID and name
 * @var string      $label   The translated label text
 * @var int|float   $value   The current value
 * @var int|float   $min     Minimum allowed value
 * @var int|float   $max     Maximum allowed value
 * @var int|float   $step    Step increment (default: 1)
 * @var string|null $suffix  Optional suffix for the output display (e.g. "°", "%")
 * @var string|null $description Optional help text below the slider
 */
$step   ??= 1;
$suffix ??= '';

?>

<div class="row">
    <label class="col-sm-3 col-form-label wt-page-options-label" for="<?php echo e($id); ?>">
        <?php echo $label; ?>
    </label>
    <div class="col-sm-9 wt-page-options-value">
        <div class="d-flex justify-content-between">
            <input id="<?php echo e($id); ?>"
                   name="<?php echo e($id); ?>"
                   class="flex-grow-1 custom-range"
                   type="range"
                   value="<?php echo e((string) $value); ?>"
                   min="<?php echo e((string) $min); ?>"
                   max="<?php echo e((string) $max); ?>"
                   step="<?php echo e((string) $step); ?>"
                   oninput="document.getElementById('<?php echo e($id); ?>Output').value = this.value + '<?php echo e($suffix); ?>'">
            <output id="<?php echo e($id); ?>Output"
                    name="<?php echo e($id); ?>Output"
                    class="custom-range-value wt-page-options-label ms-3"><?php echo e((string) $value); ?><?php echo e($suffix); ?></output>
        </div>
        <?php if (isset($description) && ($description !== '')) { ?>
            <small class="form-text text-muted">
                <?php echo $description; ?>
            </small>
        <?php } ?>
    </div>
</div>
