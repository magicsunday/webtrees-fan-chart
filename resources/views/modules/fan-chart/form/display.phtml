declare(strict_types=1);

use Fisharebest\Webtrees\I18N;
use MagicSunday\Webtrees\FanChart\Configuration;

/**
 * @var Configuration $configuration
 * @var string        $moduleName
 */
?>

<div class="row">
    <div class="col-form-label col-sm-3 wt-page-options-label">
        <?= I18N::translate('Display') ?>
    </div>
    <div class="col-sm-9 wt-page-options-value">
        <?php
            $showNames   = $configuration->getShowNames();
            $showImages  = $configuration->getShowImages();
            $displayMode = 'names';

            if ($showNames && $showImages) {
                $displayMode = 'both';
            } elseif ($showImages) {
                $displayMode = 'images';
            }
        ?>

        <div class="form-check">
            <input type="radio" class="form-check-input" name="displayMode" id="displayMode-both" value="both" <?= $displayMode === 'both' ? 'checked' : '' ?>>
            <label class="form-check-label" for="displayMode-both">
                <?= I18N::translate('Show names and images') ?>
            </label>
        </div>

        <div class="form-check">
            <input type="radio" class="form-check-input" name="displayMode" id="displayMode-names" value="names" <?= $displayMode === 'names' ? 'checked' : '' ?>>
            <label class="form-check-label" for="displayMode-names">
                <?= I18N::translate('Show names only') ?>
            </label>
        </div>

        <div class="form-check">
            <input type="radio" class="form-check-input" name="displayMode" id="displayMode-images" value="images" <?= $displayMode === 'images' ? 'checked' : '' ?>>
            <label class="form-check-label" for="displayMode-images">
                <?= I18N::translate('Show images only') ?>
            </label>
        </div>
        <small class="ps-4 form-text text-muted form-element-description" style="box-decoration-break: clone;">
            <?= I18N::translate('Images are only shown if the arc segment is wide enough. Images for descendants are not yet available.') ?>
        </small>

        <div class="mt-3">
            <?=
                view($moduleName . '::modules/components/checkbox', [
                    'name'      => 'showDescendants',
                    'label'     => I18N::translate('Show descendants'),
                    'checked'   => $configuration->getShowDescendants(),
                    'unchecked' => '0',
                ])
            ?>
            <small class="ps-4 form-text text-muted form-element-description" style="box-decoration-break: clone;">
                <?= I18N::translate('Partners and children are shown as arcs below the ancestor section. The fan size is limited to 180–270 degrees when enabled.') ?>
            </small>
        </div>

        <div class="mt-3">
            <?=
                view($moduleName . '::modules/components/checkbox', [
                    'name'      => 'hideEmptySegments',
                    'label'     => I18N::translate('Hide empty segments'),
                    'checked'   => $configuration->getHideEmptySegments(),
                    'unchecked' => '0',
                ])
            ?>
        </div>
    </div>
</div>
