                    'unchecked' => '0',
                ])
            ?>
            <small class="ps-4 form-text text-muted form-element-description" style="box-decoration-break: clone;">
                <?= I18N::translate('Displays birth and death places in the chart arcs where space allows. For descendants with many children, places are automatically suppressed. Choose the level of detail below.') ?>
            </small>
            <div class="ps-4 mt-2">
                <?=
                    view('components/select', [
                        'name'     => 'placeParts',
                        'selected' => $configuration->getPlaceParts(),
                        'options'  => $configuration->getPlacePartsList(),
                        'class'    => 'form-control-sm',
                    ])
                ?>
            </div>
        </div>

        <div class="mt-3">
            <?=
                view($moduleName . '::modules/components/checkbox', [
                    'name'      => 'showParentMarriageDates',
