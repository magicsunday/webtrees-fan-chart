                    'checked'   => $configuration->getShowParentMarriageDates(),
                    'unchecked' => '0',
                ])
            ?>
            <small class="ps-4 form-text text-muted form-element-description" style="box-decoration-break: clone;">
                <?= I18N::translate('Displays the marriage date of each couple in a narrow arc between generations. When descendants are enabled, also shows the marriage date between the central person and their partners.') ?>
            </small>
        </div>

        <div class="mt-3">
            <?=
                view($moduleName . '::modules/components/checkbox', [
                    'name'      => 'showFamilyColors',
