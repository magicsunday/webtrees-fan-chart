?>

<div class="row">
    <div class="col-form-label col-sm-3 wt-page-options-label">
        <?= I18N::translate('Layout') ?>
    </div>
    <div class="col-sm-9 wt-page-options-value">
        <?=
            view($moduleName . '::modules/components/checkbox', [
                'name'      => 'showDescendants',
                'label'     => I18N::translate('Show descendants'),
                'checked'   => $configuration->getShowDescendants(),
                'unchecked' => '0',
            ])
        ?>
        <small class="ps-4 form-text text-muted form-element-description" style="box-decoration-break: clone;">
