            <?php
            // icons/spinner was added in webtrees 2.2.6. Check without triggering
            // output buffering so the fallback works safely on older versions.
            try {
                (new View('icons/spinner'))->getFilenameForView('icons/spinner');
                echo view('icons/spinner');
            } catch (Exception) {
                echo '<span class="wt-icon-spinner"><i class="fa-solid fa-spinner fa-spin fa-3x" aria-hidden="true"></i></span>';
            }
?>
        </div>
