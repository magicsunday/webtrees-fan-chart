        <link rel="stylesheet" href="<?php echo e($stylesheet); ?>">
    <?php } ?>
<?php View::endpush(); ?>

<?php View::push('javascript'); ?>
<script src="<?php echo e($javascript); ?>"></script>
<script>
WebtreesFanChart.initPage({
