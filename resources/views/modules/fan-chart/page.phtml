/**
 * @var array         $id               The unique chart ID
 * @var Configuration $configuration
 * @var string        $title
 * @var string        $moduleName
 * @var Individual    $individual
 * @var Tree          $tree
 * @var array         $chartParams
 * @var string        $javascript
 * @var string[]      $stylesheets
 * @var string[]      $exportStylesheets A list of stylesheets used by SVG export
 * @var string        $ajaxUrl
 */
?>

<div class="webtrees-fan-chart">
    <h2 class="wt-page-title"><?php echo $title; ?></h2>

    <form id="webtrees-fan-chart-form" method="post" class="wt-page-options wt-page-options-fan-chart d-print-none">
        <?php echo csrf_field(); ?>

        <div class="row">
            <label class="col-sm-3 col-form-label wt-page-options-label" for="xref">
                <?php echo I18N::translate('Individual'); ?>
            </label>
            <div class="col-sm-9 wt-page-options-value">
                <?php echo view('components/select-individual', [
                    'name'       => 'xref',
                    'individual' => $individual,
                    'tree'       => $tree,
                    'required'   => true,
                ]);
?>
            </div>
        </div>

        <?php echo view($moduleName . '::modules/fan-chart/form/fan-size', ['moduleName' => $moduleName, 'configuration' => $configuration]); ?>
        <?php echo view($moduleName . '::modules/fan-chart/form/generations', ['moduleName' => $moduleName, 'configuration' => $configuration]); ?>

        <div class="collapse" id="showMoreOptions">
            <?php echo view($moduleName . '::modules/fan-chart/form/display', ['moduleName' => $moduleName, 'configuration' => $configuration]); ?>
            <?php echo view($moduleName . '::modules/fan-chart/form/details', ['moduleName' => $moduleName, 'configuration' => $configuration]); ?>
            <?php echo view($moduleName . '::modules/fan-chart/form/colors', ['moduleName' => $moduleName, 'configuration' => $configuration]); ?>
