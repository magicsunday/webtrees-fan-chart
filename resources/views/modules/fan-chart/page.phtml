                                aria-expanded="false"
                                aria-controls="showMoreOptions">
                            <span><?php echo I18N::translate('Show more options'); ?></span>
                            <span class="d-none"><?php echo I18N::translate('Hide more options'); ?></span>
                        </button>
                    </div>
                </div>
