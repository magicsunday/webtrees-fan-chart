{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "checkJs": true,
        "allowJs": true,
        "noEmit": true,
        "skipLibCheck": true,
        "strict": false,
        "noImplicitAny": false,
        "strictNullChecks": false,
        "lib": ["ES2022", "DOM"],
        "types": ["jest"],
        "ignoreDeprecations": "6.0",
        "baseUrl": ".",
        "paths": {
            "resources/js/modules/*": ["./resources/js/modules/*"]
        }
    },
    "include": ["resources/js/modules/**/*.js"],
    "exclude": ["node_modules"]
}
