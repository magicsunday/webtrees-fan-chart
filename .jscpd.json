{
    "format": [
        "php",
        "javascript"
    ],
    "threshold": 0,
    "reporters": [
        "console-full"
    ],
    "minTokens": 100,
    "minLines": 5,
    "path": [
        "src",
        "resources/js/modules"
    ],
    "ignore": [
        "**/*.min.js"
    ],
    "exitCode": 1
}
